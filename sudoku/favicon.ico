<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64">
  <defs>
    <linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#6366f1"/>
      <stop offset="100%" stop-color="#a855f7"/>
    </linearGradient>
  </defs>
  <rect width="64" height="64" rx="14" fill="#0f172a"/>
  <!-- 3x3 grid -->
  <rect x="12" y="12" width="11" height="11" rx="2" fill="url(#g)" opacity="0.9"/>
  <rect x="26.5" y="12" width="11" height="11" rx="2" fill="url(#g)" opacity="0.5"/>
  <rect x="41" y="12" width="11" height="11" rx="2" fill="url(#g)" opacity="0.7"/>
  <rect x="12" y="26.5" width="11" height="11" rx="2" fill="url(#g)" opacity="0.6"/>
  <rect x="26.5" y="26.5" width="11" height="11" rx="2" fill="url(#g)" opacity="0.9"/>
  <rect x="41" y="26.5" width="11" height="11" rx="2" fill="url(#g)" opacity="0.4"/>
  <rect x="12" y="41" width="11" height="11" rx="2" fill="url(#g)" opacity="0.5"/>
  <rect x="26.5" y="41" width="11" height="11" rx="2" fill="url(#g)" opacity="0.7"/>
  <rect x="41" y="41" width="11" height="11" rx="2" fill="url(#g)" opacity="0.9"/>
  <!-- Numbers -->
  <text x="17.5" y="20" font-family="Arial,sans-serif" font-weight="700" font-size="8" text-anchor="middle" fill="#fff">5</text>
  <text x="32" y="34.5" font-family="Arial,sans-serif" font-weight="700" font-size="8" text-anchor="middle" fill="#fff">9</text>
  <text x="46.5" y="49" font-family="Arial,sans-serif" font-weight="700" font-size="8" text-anchor="middle" fill="#fff">1</text>
